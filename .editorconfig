root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.{kt,kts}]
ktlint_code_style = android_studio
# Import ordering is enforced by the IDE on commit; disabled here to avoid
# CI failures on files formatted before ktlint was introduced.
ktlint_standard_import-ordering = disabled
